# ─────────────────────────────────────────────────────────────
# FlashMind — Exemplo de variáveis de ambiente
# Copie este arquivo para .env na raiz do repositório:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ─── Django ──────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_SECRET_KEY=dev-insecure-change-me-in-production-please
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api

# ─── PostgreSQL ──────────────────────────────────────────────
# Usadas pelo serviço `db` do docker-compose e pela API.
POSTGRES_DB=flashmind
POSTGRES_USER=flash
POSTGRES_PASSWORD=secret
POSTGRES_HOST=db
POSTGRES_PORT=5432

# URL completa usada pelo Django (tem precedência sobre as vars acima).
DATABASE_URL=postgres://flash:secret@db:5432/flashmind

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT ─────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── CORS ────────────────────────────────────────────────────
# Lista separada por vírgulas de origens permitidas no frontend.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Temporal ────────────────────────────────────────────────
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=flashmind-queue

# ─── LLM (Groq Cloud / Llama 3.3) ────────────────────────────
GROQ_API_KEY=gsk_replace_me
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Observabilidade ─────────────────────────────────────────
# Sentry no backend (opcional). Sem DSN, fica desabilitado — sem erro.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
LOG_LEVEL=INFO

# ─── Email (SMTP) ────────────────────────────────────────────
# Se SMTP_HOST estiver vazio, cai automaticamente pro backend
# console (email aparece no log do container `api`). Pra enviar
# email de verdade, preencha as variaveis abaixo.
#
# OPCAO 1 — Gmail (default; nao precisa de dominio)
#   1. Ative 2FA: https://myaccount.google.com/security
#   2. Crie uma App Password: https://myaccount.google.com/apppasswords
#      Copie a senha de 16 caracteres (sem espacos).
#   3. Preencha SMTP_USER com seu email Gmail e SMTP_PASSWORD com a App Password.
#   4. EMAIL_FROM precisa usar o mesmo endereco do SMTP_USER.
#   5. Limite ~500 emails/dia. Envia pra qualquer destinatario.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASSWORD=xxxxxxxxxxxxxxxx
SMTP_USE_TLS=true
EMAIL_FROM=FlashMind <seuemail@gmail.com>

# OPCAO 2 — Resend (precisa de dominio proprio em prod)
#   SMTP_HOST=smtp.resend.com
#   SMTP_USER=resend
#   SMTP_PASSWORD=re_xxx
#   EMAIL_FROM=FlashMind <noreply@seudominio.com>

# Verificacao de email (PIN de 6 digitos)
EMAIL_VERIFICATION_TTL_MINUTES=15
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_RESEND_COOLDOWN=60

# ─── Frontend (Next.js) ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SENTRY_DSN=
